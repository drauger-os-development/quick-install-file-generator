# ─────────────────────────────────────────────
#  Helpers
# ─────────────────────────────────────────────

def run(cmd: list[str], default: str | None = None) -> str | None:
    """Run a command, return stripped stdout or *default* on any failure."""
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=6)
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    except Exception:
        pass
    return default


def read_file(path: str) -> str | None:
    try:
        return Path(path).read_text().strip() or None
    except Exception:
        return None


def section(title: str) -> None:
    print(f"\n{'─' * 55}")
    print(f"  {title}")
    print(f"{'─' * 55}")


def ask(prompt: str, default: str | None = None, secret: bool = False) -> str:
    """Prompt for a required value; accepts the default on empty input."""
    hint = f" [{default}]" if default is not None else ""
    full_prompt = f"  {prompt}{hint}: "
    while True:
        value = getpass.getpass(full_prompt) if secret else input(full_prompt).strip()
        if value:
            return value
        if default is not None:
            return default
        print("  ✖  This field is required.")


def ask_optional(prompt: str, default: str | None = None) -> str | None:
    """Prompt for an optional value; empty input yields None."""
    hint = f" [{default}]" if default is not None else " [leave blank for none]"
    value = input(f"  {prompt}{hint}: ").strip()
    return value if value else default


def ask_bool(prompt: str, default: bool = False) -> bool:
    """Yes/no prompt."""
    yn = "Y/n" if default else "y/N"
    while True:
        raw = input(f"  {prompt} [{yn}]: ").strip().lower()
        if not raw:
            return default
        if raw in ("y", "yes"):
            return True
        if raw in ("n", "no"):
            return False
        print("  Please enter y or n.")


def ask_password() -> str:
    """Prompt for a password with confirmation loop."""
    while True:
        p1 = getpass.getpass("  Password for the new user: ")
        p2 = getpass.getpass("  Confirm password:          ")
        if p1 == p2:
            return p1
        print("  ✖  Passwords do not match — try again.\n")


# ─────────────────────────────────────────────
#  Auto-detection  (cross-platform)
# ─────────────────────────────────────────────

def detect_language() -> str:
    """Return a two-letter language code from the system locale."""
    loc = locale.getdefaultlocale()[0] or ""   # e.g. "en_US"
    m = re.match(r"([a-z]{2})[_.]", loc, re.IGNORECASE)
    if m:
        return m.group(1).lower()
    for source in (
        os.environ.get("LANG", ""),
        os.environ.get("LANGUAGE", ""),
        read_file("/etc/locale.gen") or "",
    ):
        m = re.match(r"([a-z]{2})[_.]", source, re.IGNORECASE)
        if m:
            return m.group(1).lower()
    return "en"


def detect_timezone() -> str:
    """Return an IANA timezone string."""
    if IS_LINUX:
        tz = read_file("/etc/timezone")
        if tz:
            return tz
        out = run(["timedatectl", "show", "--property=Timezone", "--value"])
        if out:
            return out
        try:
            link = os.readlink("/etc/localtime")
            m = re.search(r"zoneinfo/(.+)$", link)
            if m:
                return m.group(1)
        except Exception:
            pass
    if IS_WINDOWS:
        win_tz = run(["tzutil", "/g"])
        if win_tz:
            return WIN_TZ_TO_IANA.get(win_tz, win_tz)
    return "UTC"


def detect_username() -> str:
    return (
        os.environ.get("SUDO_USER")
        or os.environ.get("USER")
        or os.environ.get("USERNAME")
        or os.environ.get("LOGNAME")
        or run(["whoami"])
        or "user"
    )


def detect_hostname() -> str:
    try:
        host = socket.gethostname()
        if host:
            return host
    except Exception:
        pass
    return read_file("/etc/hostname") or "computer-name"


def detect_keyboard() -> tuple[str, str, str]:
    """Return (model, layout_label, variant_label) for the active keyboard."""
    raw_model   = None
    raw_layout  = None
    raw_variant = None

    if IS_LINUX:
        # localectl carries model, layout, and variant in one call
        out = run(["localectl", "status"])
        if out:
            for line in out.splitlines():
                stripped = line.strip()
                if stripped.startswith("X11 Model:"):
                    raw_model   = stripped.split(":", 1)[-1].strip()
                elif stripped.startswith("X11 Layout:"):
                    raw_layout  = stripped.split(":", 1)[-1].strip()
                elif stripped.startswith("X11 Variant:"):
                    raw_variant = stripped.split(":", 1)[-1].strip()

        # /etc/default/keyboard fallback (Debian/Ubuntu)
        if not raw_model:
            kb_conf = read_file("/etc/default/keyboard")
            if kb_conf:
                for line in kb_conf.splitlines():
                    if line.startswith("XKBMODEL="):
                        raw_model = line.split("=", 1)[1].strip().strip('"')

        # setxkbmap fallback for layout/variant
        if not raw_layout:
            xkb = run(["setxkbmap", "-query"])
            if xkb:
                for line in xkb.splitlines():
                    k, _, v = line.partition(":")
                    v = v.strip()
                    if k.strip() == "layout"  and v:
                        raw_layout  = v
                    if k.strip() == "variant" and v:
                        raw_variant = v
                    if k.strip() == "model"   and v and not raw_model:
                        raw_model   = v

    if IS_WINDOWS:
        ps = run([
            "powershell", "-NoProfile", "-Command",
            "(Get-WinUserLanguageList)[0].LanguageTag"
        ])
        if ps:
            tag_parts  = ps.split("-")
            raw_layout = tag_parts[1].lower() if len(tag_parts) > 1 else tag_parts[0].lower()

    model   = raw_model   or "pc105"
    layout  = raw_layout  or "us"
    variant = raw_variant or ""

    layout_label  = f"English({layout.upper()})" if layout == "us" else layout
    variant_label = (
        f"{layout_label} - {layout_label}, {variant}"
        if variant
        else f"{layout_label} - {layout_label}, euro on 5"
    )
    return model, layout_label, variant_label


def list_block_devices() -> list[str]:
    """Return lsblk lines for whole disks. Empty on non-Linux."""
    if not IS_LINUX:
        return []
    out = run(["lsblk", "-dpno", "NAME,SIZE,TYPE,MODEL", "--exclude", "7"])
    return out.splitlines() if out else []


# ─────────────────────────────────────────────
#  Partition path derivation
# ─────────────────────────────────────────────

def make_partition_path(drive: str, number: int) -> str:
    """
    Return the device path for partition *number* on *drive*.
    NVMe and MMC drives insert a 'p' before the partition number
    (e.g. /dev/nvme0n1p2, /dev/mmcblk0p1); all others append directly
    (e.g. /dev/sda2, /dev/vda3).
    """
    if re.search(r"(nvme\d+n\d+|mmcblk\d+)$", drive):
        return f"{drive}p{number}"
    return f"{drive}{number}"


def is_bare_drive(path: str) -> bool:
    """
    Return True if *path* looks like a whole disk rather than a partition.
    Whole disks end in a letter (sda, vda) or in the NVMe/MMC device suffix
    (nvme0n1, mmcblk0). Partitions end in a digit (sda1, nvme0n1p2).
    """
    return bool(re.match(
        r"^/dev/([a-z]+|nvme\d+n\d+|mmcblk\d+)$", path
    ))


# ─────────────────────────────────────────────
#  Interactive sections
# ─────────────────────────────────────────────

def gather_system_settings() -> dict:
    section("System Settings  (press Enter to accept detected value)")

    lang  = ask("Language code (e.g. en, fr, de)",          default=detect_language())
    tz    = ask("Timezone (e.g. US/Eastern, Europe/London)", default=detect_timezone())
    user  = ask("Username for the new install",              default=detect_username())
    host  = ask("Computer name (hostname)",                  default=detect_hostname())

    model_def, layout_def, variant_def = detect_keyboard()
    model   = ask("Keyboard model (e.g. pc105, pc104)",  default=model_def)
    layout  = ask("Keyboard layout label",               default=layout_def)
    variant = ask("Keyboard variant label",              default=variant_def)

    return {
        "LANG":          lang,
        "TIME_ZONE":     tz,
        "USERNAME":      user,
        "COMPUTER_NAME": host,
        "MODEL":         model,
        "LAYOUT":        layout,
        "VARIENT":       variant,    # key name preserved from template (sic)
    }


def gather_install_options() -> dict:
    section("Installation Options")

    print("""
  EXTRAS      — Install restricted extras such as proprietary media
                codecs (MP3, AAC, H.264) and NVIDIA/AMD proprietary
                GPU drivers during OS installation.

  UPDATES     — Run a full system update (apt upgrade / dnf update /
                etc.) as part of the installation process. Useful for
                air-gapped setups where you want to defer this step.

  LOGIN       — Enable automatic login for the new user so the desktop
                loads without a password prompt on boot.

  COMPAT_MODE — Bootloader Compatibility Mode. Installs systemd-boot
                in its standard EFI location AND overwrites the Windows
                Boot Manager path (EFI/Microsoft/Boot/bootmgfw.efi),
                tricking locked-down UEFI firmware that only allows the
                Windows bootloader to run Linux. Enable this on machines
                with overly restrictive OEM UEFI implementations.
""")

    extras      = ask_bool("Install restricted extras (EXTRAS)?",                default=True)
    updates     = ask_bool("Run updates during installation (UPDATES)?",          default=False)
    login       = ask_bool("Enable auto-login (LOGIN)?",                          default=False)
    compat_mode = ask_bool("Enable Bootloader Compatibility Mode (COMPAT_MODE)?", default=False)

    return {
        "EXTRAS":      extras,
        "UPDATES":     updates,
        "LOGIN":       login,
        "COMPAT_MODE": compat_mode,
    }


def gather_partitions() -> dict:
    section("Disk Partitioning")

    auto_part = ask_bool("Use automatic partitioning (AUTO_PART)?", default=False)

    root = efi = home = swap = None

    if auto_part:
        if ask_bool("Create a dedicated /home partition on the same drive (HOME)?",
                    default=False):
            home = "MAKE"

    if not auto_part:
        devices = list_block_devices()
        if devices:
            print("\n  Drives detected:")
            for d in devices:
                print(f"    {d}")
            print()
        elif IS_WINDOWS:
            print("""
  Drive detection is unavailable on Windows. Boot a Linux live
  environment and run:  lsblk -dpno NAME,SIZE,MODEL
  to identify the target drive before proceeding.
""")

        drive = ask("Drive to install on (e.g. /dev/sda, /dev/nvme0n1)")

        print(f"""
  Partition the drive yourself in GParted (or similar) before running
  the installer, then tell us what order you placed the partitions in.

  Available partition types:
    EFI   — FAT32, ~512 MB, boot/EFI flags                  (required)
    ROOT  — ext4 or preferred filesystem, rest of drive      (required)
    HOME  — separate /home partition                         (optional)
    SWAP  — swap space                                       (optional)

  HOME may be left out here if you want to place it on a different
  drive entirely — you will be asked about that separately.

  Enter types in the order they appear on the disk, comma-separated.
  Examples:
    EFI,ROOT
    EFI,ROOT,SWAP
    EFI,ROOT,HOME,SWAP
""")

        VALID    = {"EFI", "ROOT", "HOME", "SWAP"}
        REQUIRED = {"EFI", "ROOT"}

        while True:
            raw   = ask("Partition order").upper()
            order = [p.strip() for p in raw.split(",") if p.strip()]

            unknown    = [p for p in order if p not in VALID]
            missing    = REQUIRED - set(order)
            duplicates = [p for p in VALID if order.count(p) > 1]

            if unknown:
                print(f"  ✖  Unknown type(s): {', '.join(unknown)}")
                print(f"     Valid types: {', '.join(sorted(VALID))}")
            elif missing:
                print(f"  ✖  Required partition(s) missing: {', '.join(missing)}")
            elif duplicates:
                print(f"  ✖  Duplicate type(s): {', '.join(duplicates)}")
            else:
                break

        assigned = {
            ptype: make_partition_path(drive, idx + 1)
            for idx, ptype in enumerate(order)
        }

        efi  = assigned.get("EFI")
        root = assigned.get("ROOT")
        home = assigned.get("HOME")
        swap = assigned.get("SWAP")

        # Offer a swap file if SWAP wasn't placed on the main drive
        if swap is None:
            if ask_bool("Use a swap file instead of a swap partition (SWAP=FILE)?",
                        default=False):
                swap = "FILE"

        # HOME on a separate drive
        if home is None:
            if ask_bool("Place /home on a separate drive?", default=False):
                home_devices = list_block_devices()
                if home_devices:
                    print("\n  Drives detected:")
                    for d in home_devices:
                        print(f"    {d}")
                    print()
                while True:
                    home_path = ask(
                        "Device path for /home (e.g. /dev/sdb1, /dev/nvme1n1p2)"
                    )
                    if is_bare_drive(home_path):
                        print("""
  ⚠  Warning: you entered a bare drive path with no partition number.
  This is only valid when BTRFS is taking over the entire disk as
  part of a RAID array — in that case there is no partition table,
  so the raw drive path mounts correctly.
  If you are not sure whether this applies to you, it almost
  certainly does not. A normal partition path (e.g. /dev/sdb1)
  is likely what you need instead.
""")
                        if ask_bool("Proceed with this bare drive path anyway?", default=False):
                            home = home_path
                            break
                        # declined — loop back and ask again
                    else:
                        home = home_path
                        break

        print(f"\n  Resolved partition paths:")
        print(f"    EFI:  {efi  or '—'}")
        print(f"    ROOT: {root or '—'}")
        print(f"    HOME: {home or '—'}")
        print(f"    SWAP: {swap or '—'}")

    return {
        "AUTO_PART": auto_part,
        "ROOT":      root,
        "EFI":       efi,
        "HOME":      home,
        "SWAP":      swap,
    }


def gather_raid() -> dict:
    section("RAID Configuration")

    use_raid = ask_bool("Configure a software RAID array?", default=False)
    disks: dict[str, str | None] = {"1": None, "2": None, "3": None, "4": None}

    if not use_raid:
        return {"raid_type": None, "disks": disks}

    print("""
  RAID levels:
    0  — striping only (speed, no redundancy)
    1  — mirroring (redundancy, requires ≥ 2 disks)
    10 — mirrored stripes (requires ≥ 4 disks)

  Note: only RAID 0, 1, and 10 are supported, as these are the only
  modes supported by BTRFS.
""")

    devices = list_block_devices()
    if devices:
        print("  Available drives:")
        for d in devices:
            print(f"    {d}")
        print()

    while True:
        raid_type = ask("RAID level (0 / 1 / 10)")
        if raid_type in ("0", "1", "10"):
            break
        print(f"  ✖  Invalid RAID level '{raid_type}'. Must be 0, 1, or 10.")

    disks: dict[str, str | None] = {}
    i = 1
    while True:
        val = ask_optional(f"RAID disk {i} path (e.g. /dev/sdb, blank to finish)")
        if val:
            disks[str(i)] = val
            i += 1
        else:
            if i < 3:
                print(f"  ✖  At least 2 disks are required for a RAID array. "
                      f"Please add disk {i}.")
            else:
                break

    return {"raid_type": raid_type, "disks": disks}


# ─────────────────────────────────────────────
#  Carry-over: wallpaper
# ─────────────────────────────────────────────

def find_wallpaper() -> str | None:
    """
    Try to locate the current desktop wallpaper file.
    Returns an absolute path string, or None if it cannot be found.
    """
    if IS_LINUX:
        # GNOME / GNOME-based (Ubuntu, Fedora, Pop!_OS …)
        for prop in ("picture-uri", "picture-uri-dark"):
            uri = run(["gsettings", "get", "org.gnome.desktop.background", prop])
            if uri:
                uri = uri.strip("'\" ")
                path = uri[len("file://"):] if uri.startswith("file://") else uri
                if path and Path(path).is_file():
                    return path

        # KDE Plasma
        plasma_cfg = Path.home() / ".config" / "plasma-org.kde.plasma.desktop-appletsrc"
        if plasma_cfg.exists():
            for line in plasma_cfg.read_text(errors="replace").splitlines():
                if "Image=" in line:
                    val = line.split("=", 1)[-1].strip()
                    if val.startswith("file://"):
                        val = val[len("file://"):]
                    if val and Path(val).is_file():
                        return val

        # XFCE
        xfconf = run(["xfconf-query", "-c", "xfce4-desktop", "-lv"])
        if xfconf:
            for line in xfconf.splitlines():
                if "last-image" in line or "image-path" in line:
                    parts = line.split()
                    if parts:
                        candidate = parts[-1]
                        if Path(candidate).is_file():
                            return candidate

    if IS_WINDOWS:
        # Registry (works for solid-color and file wallpapers)
        try:
            import winreg
            key = winreg.OpenKey(winreg.HKEY_CURRENT_USER, r"Control Panel\Desktop")
            val, _ = winreg.QueryValueEx(key, "Wallpaper")
            winreg.CloseKey(key)
            if val and Path(val).is_file():
                return val
        except Exception:
            pass

        # Transcoded cache — Windows writes the active wallpaper here
        # even when the original is a slideshow or theme asset
        cache = (
            Path.home()
            / "AppData" / "Roaming" / "Microsoft"
            / "Windows" / "Themes" / "TranscodedWallpaper"
        )
        if cache.exists():
            return str(cache)

    return None


# ─────────────────────────────────────────────
#  Carry-over: network (Windows synthesis)
# ─────────────────────────────────────────────

def _indent(level: int, text: str) -> str:
    return "  " * level + text


def synthesize_netplan_windows() -> list[tuple[str, str]]:
    """
    Attempt to generate netplan-compatible YAML from Windows network config.
    Returns a list of (filename, yaml_content) pairs. Empty on total failure.
    WiFi password extraction requires the process to be running as Administrator.
    """
    results: list[tuple[str, str]] = []

    # ── Ethernet / static IP via PowerShell ──────────────────
    ps_out = run([
        "powershell", "-NoProfile", "-Command",
        "Get-NetIPConfiguration | ConvertTo-Json -Depth 5",
    ])
    if ps_out:
        try:
            raw = json.loads(ps_out)
            adapters = raw if isinstance(raw, list) else [raw]
            lines = ["network:", _indent(1, "version: 2"), _indent(1, "ethernets:")]

            for adapter in adapters:
                alias = adapter.get("InterfaceAlias", "eth0")
                safe  = re.sub(r"[^a-zA-Z0-9_-]", "_", alias)

                ipv4_info = adapter.get("IPv4Address")
                gw_info   = adapter.get("IPv4DefaultGateway")
                dns_info  = adapter.get("DNSServer", [])

                if isinstance(ipv4_info, list):
                    ipv4_info = ipv4_info[0] if ipv4_info else None
                if isinstance(gw_info, list):
                    gw_info = gw_info[0] if gw_info else None

                lines.append(_indent(2, f"{safe}:"))

                if ipv4_info and isinstance(ipv4_info, dict):
                    addr   = ipv4_info.get("IPAddress", "")
                    prefix = ipv4_info.get("PrefixLength", 24)
                    if addr:
                        lines.append(_indent(3, "dhcp4: false"))
                        lines.append(_indent(3, "addresses:"))
                        lines.append(_indent(4, f"- {addr}/{prefix}"))
                    else:
                        lines.append(_indent(3, "dhcp4: true"))
                else:
                    lines.append(_indent(3, "dhcp4: true"))

                if gw_info and isinstance(gw_info, dict):
                    via = gw_info.get("NextHop", "")
                    if via:
                        lines.append(_indent(3, "routes:"))
                        lines.append(_indent(4, "- to: default"))
                        lines.append(_indent(5, f"via: {via}"))

                dns_addrs: list[str] = []
                for entry in (dns_info if isinstance(dns_info, list) else [dns_info]):
                    if isinstance(entry, dict):
                        dns_addrs.extend(entry.get("ServerAddresses", []))
                    elif isinstance(entry, str):
                        dns_addrs.append(entry)
                if dns_addrs:
                    formatted = "[" + ", ".join(f'"{a}"' for a in dns_addrs) + "]"
                    lines.append(_indent(3, "nameservers:"))
                    lines.append(_indent(4, f"addresses: {formatted}"))

            results.append(("01-ethernet.yaml", "\n".join(lines) + "\n"))
        except Exception:
            pass

    # ── WiFi profiles via netsh ───────────────────────────────
    profiles_raw = run(["netsh", "wlan", "show", "profiles"])
    if profiles_raw:
        profile_names = re.findall(r"All User Profile\s*:\s*(.+)", profiles_raw)
        wifi_lines = ["network:", _indent(1, "version: 2"), _indent(1, "wifis:")]
        found_any = False

        for name in profile_names:
            name   = name.strip()
            detail = run(["netsh", "wlan", "show", "profile",
                          f"name={name}", "key=clear"])
            if not detail:
                continue

            ssid_m = re.search(r'SSID name\s*:\s*"(.+)"', detail)
            pass_m = re.search(r"Key Content\s*:\s*(.+)", detail)
            if not ssid_m:
                continue

            ssid  = ssid_m.group(1)
            safe  = re.sub(r"[^a-zA-Z0-9_-]", "_", name)
            found_any = True

            wifi_lines.append(_indent(2, f"{safe}:"))
            wifi_lines.append(_indent(3, "dhcp4: true"))
            wifi_lines.append(_indent(3, "access-points:"))
            wifi_lines.append(_indent(4, f'"{ssid}":'))
            if pass_m:
                wifi_lines.append(_indent(5, f'password: "{pass_m.group(1).strip()}"'))

        if found_any:
            results.append(("02-wifi.yaml", "\n".join(wifi_lines) + "\n"))

    return results


# ─────────────────────────────────────────────
#  Carry-over: prompts & archive writer
# ─────────────────────────────────────────────

def gather_carry_over() -> dict:
    section("Carry-Over Settings")

    print("""
  These settings can be bundled with your install config so the
  installer can restore them on the new system automatically.
""")

    wallpaper = ask_bool("Carry over current wallpaper?",       default=False)
    network   = ask_bool("Carry over network settings?",        default=False)

    return {"wallpaper": wallpaper, "network": network}


def fix_ownership(path: str) -> None:
    """
    On Linux, when the script was invoked via sudo, the output file ends up
    owned by root. This restores ownership to the real (pre-sudo) user and
    their primary group so they can handle the file normally afterwards.
    Does nothing on Windows or when not running under sudo.
    """
    if not IS_LINUX:
        return
    real_user = os.environ.get("SUDO_USER")
    if not real_user:
        return
    try:
        import pwd
        pw = pwd.getpwnam(real_user)
        os.chown(path, pw.pw_uid, pw.pw_gid)
    except Exception as e:
        print(f"  ⚠  Could not restore file ownership: {e}")


def write_output(config: dict, out_path: str, carry: dict) -> None:
    """
    Write either a plain JSON file or a tar.xz archive depending on
    whether any carry-over options were selected.
    """
    use_archive = carry["wallpaper"] or carry["network"]

    if not use_archive:
        with open(out_path, "w") as f:
            json.dump(config, f, indent="\t")
        fix_ownership(out_path)
        print(f"\n  ✔  Config written to: {out_path}\n")
        return

    # ── Build the archive in a temporary directory ────────────
    with tempfile.TemporaryDirectory() as tmp:
        settings = Path(tmp) / "settings"
        settings.mkdir()

        # Always include the JSON config
        with open(settings / "installation-settings.json", "w") as f:
            json.dump(config, f, indent="\t")

        # ── Network settings ──────────────────────────────────
        if carry["network"]:
            if IS_LINUX:
                nm_dir = settings / "network-settings"
                nm_dir.mkdir()
                nm_src = Path("/etc/NetworkManager/system-connections")
                if nm_src.is_dir():
                    for item in nm_src.iterdir():
                        try:
                            shutil.copy2(item, nm_dir / item.name)
                        except Exception as e:
                            print(f"  ⚠  Could not copy {item.name}: {e}")

                np_dir = settings / "network-settings-NP"
                np_dir.mkdir()
                np_src = Path("/etc/netplan")
                if np_src.is_dir():
                    for item in np_src.glob("*.yaml"):
                        try:
                            shutil.copy2(item, np_dir / item.name)
                        except Exception as e:
                            print(f"  ⚠  Could not copy {item.name}: {e}")

            elif IS_WINDOWS:
                np_dir = settings / "network-settings-NP"
                np_dir.mkdir()
                synthesized = synthesize_netplan_windows()
                if synthesized:
                    for filename, content in synthesized:
                        (np_dir / filename).write_text(content, encoding="utf-8")
                    print(f"  ✔  Synthesized {len(synthesized)} netplan file(s) from Windows config.")
                else:
                    print("  ⚠  Could not synthesize any netplan config from Windows.")
                    print("     You may need to configure networking manually after install.")

        # ── Wallpaper ─────────────────────────────────────────
        assets_root = None
        if carry["wallpaper"]:
            wp_src = find_wallpaper()
            if wp_src:
                ext        = Path(wp_src).suffix or ".jpg"  # TranscodedWallpaper has no ext but is always JPEG
                assets_dir = Path(tmp) / "assets" / "master"
                assets_dir.mkdir(parents=True)
                wp_dest = assets_dir / f"wallpaper{ext}"
                try:
                    shutil.copy2(wp_src, wp_dest)
                    print(f"  ✔  Wallpaper included as: assets/master/wallpaper{ext}")
                    assets_root = Path(tmp) / "assets"    # only set on success
                except Exception as e:
                    print(f"  ⚠  Could not copy wallpaper: {e}")
            else:
                print("  ⚠  Could not detect wallpaper path — skipping.")

        # ── Pack into tar.xz ──────────────────────────────────
        try:
            with tarfile.open(out_path, "w:xz") as tar:
                tar.add(settings, arcname="settings")
                if assets_root is not None:
                    tar.add(assets_root, arcname="assets")
            fix_ownership(out_path)
            print(f"\n  ✔  Config archive written to: {out_path}\n")
        except Exception as e:
            print(f"\n  ✖  Could not write archive: {e}", file=sys.stderr)
            sys.exit(1)


# ─────────────────────────────────────────────
#  Main
# ─────────────────────────────────────────────

def main() -> None:
    args = parse_args()
    if args.version:
        print_version()
        sys.exit(0)
    if args.help:
        print_help()
        sys.exit(0)

    ensure_tty()
    ensure_elevated()

    print()
    print("╔══════════════════════════════════════════════════════╗")
    print("║      Linux Quick-Install Config Generator            ║")
    print("╚══════════════════════════════════════════════════════╝")
    print()

    if IS_WINDOWS:
        print("  Running on Windows — language, timezone, username,")
        print("  hostname, and keyboard settings will be detected from")
        print("  Windows. Drive/partition paths must be entered manually.")
    elif IS_LINUX:
        print("  Running on Linux — most settings will be auto-detected.")
    else:
        print(f"  Running on {OS} — detection may be limited.")

    print()

    system   = gather_system_settings()

    section("User Password")
    password = ask_password()

    options  = gather_install_options()
    parts    = gather_partitions()
    raid     = gather_raid()
    carry    = gather_carry_over()

    section("Output")
    default_name = (
        "install-config.tar.xz" if (carry["wallpaper"] or carry["network"])
        else "install-config.json"
    )
    default_path = str(Path.cwd() / default_name)
    print(f"\n  Current directory: {Path.cwd()}")
    print( "  You may enter a filename, a relative path, or a full path.\n")
    out_path = ask_optional("Save config to", default=default_path) or default_path
    out_path = str(Path(out_path).expanduser().resolve())

    # Enforce correct extension based on output mode
    if carry["wallpaper"] or carry["network"]:
        if not out_path.endswith(".tar.xz"):
            out_path = re.sub(r"(\.(json|tar\.xz))?$", ".tar.xz", out_path)
    else:
        if not out_path.endswith(".json"):
            out_path = re.sub(r"(\.(json|tar\.xz))?$", ".json", out_path)

    print(f"\n  Output will be saved to: {out_path}")

    config = {
        "DATA": {
            "LANG":          system["LANG"],
            "TIME_ZONE":     system["TIME_ZONE"],
            "AUTO_PART":     parts["AUTO_PART"],
            "ROOT":          parts["ROOT"],
            "EFI":           parts["EFI"],
            "HOME":          parts["HOME"],
            "SWAP":          parts["SWAP"],
            "USERNAME":      system["USERNAME"],
            "PASSWORD":      password,
            "COMPUTER_NAME": system["COMPUTER_NAME"],
            "EXTRAS":        options["EXTRAS"],
            "UPDATES":       options["UPDATES"],
            "LOGIN":         options["LOGIN"],
            "COMPAT_MODE":   options["COMPAT_MODE"],
            "MODEL":         system["MODEL"],
            "LAYOUT":        system["LAYOUT"],
            "VARIENT":       system["VARIENT"],
            "raid_array": {
                "raid_type": raid["raid_type"],
                "disks":     raid["disks"],
            },
        },
        "COMMENTS": [
            "Generated by gen_install_config.py.",
            "Any comments can be added to this field.",
            "Everything must follow JSON syntax.",
            "The DATA field holds all installer settings.",
            "Remove this COMMENTS field if not needed.",
        ],
    }

    write_output(config, out_path, carry)

    print("  Preview (installation-settings.json):")
    print("  " + json.dumps(config, indent=2).replace("\n", "\n  "))

    print("""
╔══════════════════════════════════════════════════════╗
║                  ⚠  SECURITY WARNING  ⚠              ║
╠══════════════════════════════════════════════════════╣
║  Your password is stored in PLAIN TEXT in the        ║
║  config file. It is NOT encrypted or hashed.         ║
║                                                      ║
║  DO NOT share this file with anyone without first    ║
║  removing the PASSWORD field.                        ║
╚══════════════════════════════════════════════════════╝""")


if __name__ == "__main__":
    main()
