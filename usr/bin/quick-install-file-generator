"""
gen_install_config.py
---------------------
Generates a Linux quick-install configuration JSON by auto-detecting
system settings where possible and prompting the user for the rest.

Runs on Linux (full detection) and Windows (partial detection).
Output format matches quick-install-template.json.
"""

import argparse
import json
import locale
import os
import platform
import re
import shlex
import shutil
import socket
import sys
import tarfile
import tempfile
import getpass
import subprocess
from pathlib import Path

OS         = platform.system()   # "Linux", "Windows", "Darwin"
IS_LINUX   = OS == "Linux"
IS_WINDOWS = OS == "Windows"

VERSION = "0.1.3-alpha1"


# ─────────────────────────────────────────────
#  CLI flags, TTY check, privilege check
# ─────────────────────────────────────────────

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("-v", "--version", action="store_true",
                        help="Print version and exit.")
    parser.add_argument("-h", "--help", action="store_true",
                        help="Print this help message and exit.")
    return parser.parse_args()


def print_version() -> None:
    print(f"gen_install_config v{VERSION}")


def print_help() -> None:
    print(f"""\
gen_install_config v{VERSION}

Generates a Linux quick-install configuration file by auto-detecting
settings from the current system and prompting for anything it cannot
determine automatically.

When wallpaper or network carry-over is selected the output becomes an
Advanced Quick Install File — a .tar.xz archive containing the install-
settings JSON alongside any carried-over files (wallpaper, NetworkManager
profiles, netplan config). On Windows, netplan files are synthesized from
the active network config.

Usage:
  gen_install_config [options]

Options:
  -h, --help     Show this help message and exit.
  -v, --version  Show the version number and exit.

Requirements:
  Must be run with administrator / root privileges so that network
  configuration files can be read.
  Must be run inside an interactive terminal; if launched headlessly
  (e.g. by double-clicking) a terminal window will be spawned
  automatically.\
""")


def _build_relaunch_cmd() -> list[str]:
    """Return the command needed to re-launch this process."""
    # Compiled binary (Nuitka): argv[0] is already the executable.
    # Python script: prepend the interpreter.
    if sys.argv[0].endswith((".py", ".pyw")):
        return [sys.executable] + sys.argv
    return sys.argv


def ensure_tty() -> None:
    """If not running in an interactive terminal, spawn one and exit."""
    if sys.stdin.isatty():
        return

    cmd = _build_relaunch_cmd()

    if IS_WINDOWS:
        # Prefer Windows Terminal; fall back to a plain new console window.
        try:
            subprocess.Popen(["wt"] + cmd)
        except FileNotFoundError:
            subprocess.Popen(cmd, creationflags=subprocess.CREATE_NEW_CONSOLE)
        sys.exit(0)

    # Linux / other: try common terminal emulators in order of preference.
    # Some accept a command list after '--' or '-e'; others need a single
    # shell string — those get shlex.join() treatment.
    cmd_str = shlex.join(cmd)
    terminals: list[list[str]] = [
        ["gnome-terminal", "--"] + cmd,
        ["konsole",        "-e"] + cmd,
        ["tilix",          "-e"] + cmd,
        ["xterm",          "-e"] + cmd,
        ["xfce4-terminal", "-e", cmd_str],
        ["lxterminal",     "-e", cmd_str],
        ["mate-terminal",  "-e", cmd_str],
    ]
    for term_cmd in terminals:
        try:
            subprocess.Popen(term_cmd)
            sys.exit(0)
        except FileNotFoundError:
            continue

    print("✖  Not running in a terminal and no terminal emulator was found.",
          file=sys.stderr)
    print("   Please launch this script from an interactive terminal.",
          file=sys.stderr)
    input("Press Enter to exit...")
    sys.exit(1)


def ensure_elevated() -> None:
    """Exit with an error if the process does not have admin / root privileges."""
    if IS_WINDOWS:
        try:
            import ctypes
            elevated = ctypes.windll.shell32.IsUserAnAdmin() != 0
        except Exception:
            elevated = False
    else:
        elevated = (os.geteuid() == 0)

    if not elevated:
        print("✖  This tool must be run with elevated privileges.", file=sys.stderr)
        if IS_WINDOWS:
            print("   Right-click the file and choose 'Run as administrator'.",
                  file=sys.stderr)
        else:
            print("   Please re-run with:  sudo gen_install_config",
                  file=sys.stderr)
        input("Press Enter to exit...")
        sys.exit(1)

